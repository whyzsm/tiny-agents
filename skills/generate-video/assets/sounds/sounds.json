{
  "$schema": "../../schemas/sounds.schema.json",
  "version": "1.0.0",
  "sounds": [
    {
      "id": "impact",
      "name": "Impact",
      "description": "High-impact sound for strong emphasis and reveals",
      "type": "effect",
      "category": "emphasis",
      "emphasis_level": "high",
      "file": {
        "placeholder": "impact.mp3",
        "expected_duration": 0.5,
        "expected_size": 8000,
        "format": "mp3",
        "sample_rate": 44100,
        "bit_depth": 16
      },
      "usage": {
        "scenes": ["hook", "reveal", "differentiator", "cta"],
        "timing": "On visual appearance or text reveal",
        "recommended_for": "Dramatic reveals, key differentiators, CTAs, opening hooks",
        "avoid_for": "Frequent usage (max 2-3 per video), background content"
      },
      "volume": {
        "default": 0.7,
        "with_narration": 0.4,
        "with_bgm": 0.6,
        "range": [0.3, 1.0]
      },
      "timing": {
        "offset_before_visual": 0,
        "fade_in_duration": 0.05,
        "fade_out_duration": 0.1
      },
      "alternatives": {
        "softer": "pop",
        "silent": "none"
      }
    },
    {
      "id": "pop",
      "name": "Pop",
      "description": "Medium emphasis sound for important but not critical points",
      "type": "effect",
      "category": "emphasis",
      "emphasis_level": "medium",
      "file": {
        "placeholder": "pop.mp3",
        "expected_duration": 0.3,
        "expected_size": 5000,
        "format": "mp3",
        "sample_rate": 44100,
        "bit_depth": 16
      },
      "usage": {
        "scenes": ["feature", "benefit", "step"],
        "timing": "On list item appearance or icon display",
        "recommended_for": "Feature lists, benefit points, step completions, card reveals",
        "avoid_for": "Every single element (use sparingly)"
      },
      "volume": {
        "default": 0.5,
        "with_narration": 0.25,
        "with_bgm": 0.4,
        "range": [0.2, 0.7]
      },
      "timing": {
        "offset_before_visual": 0,
        "fade_in_duration": 0.02,
        "fade_out_duration": 0.08
      },
      "alternatives": {
        "stronger": "impact",
        "softer": "subtle",
        "silent": "none"
      }
    },
    {
      "id": "transition",
      "name": "Transition",
      "description": "Scene transition sound for smooth flow between sections",
      "type": "effect",
      "category": "transition",
      "emphasis_level": "low",
      "file": {
        "placeholder": "transition.mp3",
        "expected_duration": 0.4,
        "expected_size": 6000,
        "format": "mp3",
        "sample_rate": 44100,
        "bit_depth": 16
      },
      "usage": {
        "scenes": ["all_transitions"],
        "timing": "At scene boundary (during visual transition)",
        "recommended_for": "Scene changes, section transitions, topic shifts",
        "avoid_for": "Within-scene content changes"
      },
      "volume": {
        "default": 0.4,
        "with_narration": 0.2,
        "with_bgm": 0.3,
        "range": [0.1, 0.5]
      },
      "timing": {
        "offset_before_visual": -0.1,
        "fade_in_duration": 0.1,
        "fade_out_duration": 0.15
      },
      "alternatives": {
        "silent": "none"
      }
    },
    {
      "id": "subtle",
      "name": "Subtle",
      "description": "Low-emphasis sound for minimal feedback",
      "type": "effect",
      "category": "emphasis",
      "emphasis_level": "low",
      "file": {
        "placeholder": "subtle.mp3",
        "expected_duration": 0.2,
        "expected_size": 3000,
        "format": "mp3",
        "sample_rate": 44100,
        "bit_depth": 16
      },
      "usage": {
        "scenes": ["content", "detail", "supplementary"],
        "timing": "On minor element appearance",
        "recommended_for": "Supporting details, minor UI changes, progress indicators",
        "avoid_for": "Key messages (use pop or impact instead)"
      },
      "volume": {
        "default": 0.3,
        "with_narration": 0.15,
        "with_bgm": 0.25,
        "range": [0.1, 0.4]
      },
      "timing": {
        "offset_before_visual": 0,
        "fade_in_duration": 0.02,
        "fade_out_duration": 0.05
      },
      "alternatives": {
        "stronger": "pop",
        "silent": "none"
      }
    }
  ],
  "guidelines": {
    "frequency": {
      "impact": "Maximum 2-3 per video (reserve for critical moments)",
      "pop": "Up to 5-8 per video (key features/benefits)",
      "transition": "All scene transitions (if enabled)",
      "subtle": "Up to 10-15 per video (supporting elements)"
    },
    "combinations": {
      "with_narration": "Use lower volumes to avoid competing with voice",
      "with_bgm": "Use moderate volumes, BGM should be ducked during effects",
      "without_audio": "Use default volumes for maximum impact"
    },
    "timing_best_practices": {
      "sync_with_visual": "Effect should start exactly when visual appears (offset: 0)",
      "early_for_anticipation": "Start 0.05-0.1s before for dramatic effect",
      "avoid_overlap": "Ensure effects don't overlap unless intentional"
    }
  },
  "fallback": {
    "if_file_missing": "Continue without sound effect (silent)",
    "if_user_disabled": "Respect user preference (no effects)",
    "placeholder_sources": [
      "https://freesound.org/ (CC0 or CC BY licensed)",
      "User-provided sounds in ~/.harness/video/assets/sounds/",
      "Generate procedural sounds with Web Audio API"
    ]
  },
  "metadata": {
    "created_at": "2026-02-02",
    "updated_at": "2026-02-02",
    "author": "Claude Code",
    "note": "These are configuration presets. Actual audio files are placeholders. Users should provide real audio files or use defaults from public libraries."
  }
}
