{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.dev/schemas/video/character.schema.json",
  "title": "Character Schema",
  "description": "Phase 10: Character definition for future character dialogue videos (version 1.0.0)",
  "type": "object",
  "required": ["character_id", "name", "voice", "appearance"],
  "properties": {
    "character_id": {
      "type": "string",
      "description": "Unique identifier for the character",
      "pattern": "^[a-z0-9-]+$",
      "examples": ["narrator", "user", "assistant", "expert-reviewer"]
    },
    "name": {
      "type": "string",
      "description": "Display name of the character",
      "minLength": 1,
      "maxLength": 100,
      "examples": ["Narrator", "Alice (User)", "AI Assistant", "Expert"]
    },
    "role": {
      "type": "string",
      "description": "Role in the dialogue",
      "enum": [
        "narrator",
        "protagonist",
        "guide",
        "expert",
        "user",
        "system",
        "interviewer",
        "interviewee"
      ],
      "default": "narrator"
    },
    "voice": {
      "type": "object",
      "description": "Text-to-Speech (TTS) voice configuration",
      "required": ["provider"],
      "properties": {
        "provider": {
          "type": "string",
          "description": "TTS provider",
          "enum": ["google-cloud-tts", "elevenlabs", "openai-tts", "aws-polly", "aivis", "voicevox", "custom"],
          "examples": ["google-cloud-tts", "elevenlabs", "aivis"]
        },
        "voice_id": {
          "type": "string",
          "description": "Voice identifier specific to the provider",
          "examples": [
            "en-US-Neural2-D",
            "elevenlabs:josh",
            "alloy",
            "custom-voice-001"
          ]
        },
        "language": {
          "type": "string",
          "description": "Language code (ISO 639-1 or BCP 47)",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "default": "ja",
          "examples": ["ja", "en-US", "en-GB", "es"]
        },
        "gender": {
          "type": "string",
          "description": "Voice gender (for filtering/selection)",
          "enum": ["male", "female", "neutral", "unspecified"]
        },
        "pitch": {
          "type": "number",
          "description": "Pitch adjustment (-20.0 to 20.0 semitones)",
          "minimum": -20,
          "maximum": 20,
          "default": 0
        },
        "speed": {
          "type": "number",
          "description": "Speaking rate (0.25 to 4.0, 1.0 is normal)",
          "minimum": 0.25,
          "maximum": 4.0,
          "default": 1.0
        },
        "volume": {
          "type": "number",
          "description": "Volume gain in dB (-96.0 to 16.0)",
          "minimum": -96,
          "maximum": 16,
          "default": 0
        },
        "style": {
          "type": "string",
          "description": "Speaking style (provider-dependent)",
          "enum": [
            "neutral",
            "cheerful",
            "empathetic",
            "calm",
            "professional",
            "friendly",
            "authoritative",
            "conversational"
          ],
          "default": "neutral"
        },
        "emotion": {
          "type": "string",
          "description": "Emotional tone (for advanced TTS)",
          "enum": [
            "neutral",
            "happy",
            "sad",
            "angry",
            "fearful",
            "surprised",
            "excited"
          ],
          "default": "neutral"
        },
        "aivis": {
          "type": "object",
          "description": "Aivis Cloud API specific settings (for provider: 'aivis')",
          "properties": {
            "speaker_id": {
              "type": "integer",
              "description": "Speaker ID (Aivis model specific)",
              "minimum": 0,
              "examples": [888753760, 888753761, 888753762]
            },
            "intonation_scale": {
              "type": "number",
              "description": "Intonation scale (0.0-2.0, 1.0 is normal)",
              "minimum": 0.0,
              "maximum": 2.0,
              "default": 1.0
            },
            "pre_phoneme_length": {
              "type": "number",
              "description": "Pre-phoneme silence length in seconds",
              "minimum": 0.0,
              "default": 0.1
            },
            "post_phoneme_length": {
              "type": "number",
              "description": "Post-phoneme silence length in seconds",
              "minimum": 0.0,
              "default": 0.1
            }
          }
        },
        "voicevox": {
          "type": "object",
          "description": "VOICEVOX specific settings (for provider: 'voicevox')",
          "properties": {
            "speaker_id": {
              "type": "integer",
              "description": "Speaker ID (e.g., 1=ずんだもん, 3=四国めたん)",
              "minimum": 0,
              "examples": [1, 3, 8, 13]
            },
            "intonation_scale": {
              "type": "number",
              "description": "Intonation scale",
              "minimum": 0.0,
              "maximum": 2.0,
              "default": 1.0
            },
            "volume_scale": {
              "type": "number",
              "description": "Volume scale",
              "minimum": 0.0,
              "maximum": 2.0,
              "default": 1.0
            }
          }
        }
      }
    },
    "appearance": {
      "type": "object",
      "description": "Visual appearance configuration (for character dialogue videos)",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Visual representation type",
          "enum": ["avatar", "icon", "image", "video", "none"],
          "default": "avatar"
        },
        "avatar": {
          "type": "object",
          "description": "Avatar configuration (for type: 'avatar')",
          "properties": {
            "style": {
              "type": "string",
              "enum": ["realistic", "cartoon", "minimalist", "pixel-art", "abstract"],
              "default": "minimalist"
            },
            "base_image": {
              "type": "string",
              "description": "Path to base avatar image"
            },
            "expressions": {
              "type": "object",
              "description": "Expression image paths (for different emotions)",
              "properties": {
                "neutral": {
                  "type": "string",
                  "description": "Path to neutral expression image"
                },
                "happy": {
                  "type": "string"
                },
                "sad": {
                  "type": "string"
                },
                "surprised": {
                  "type": "string"
                },
                "thinking": {
                  "type": "string"
                },
                "speaking": {
                  "type": "string"
                }
              }
            },
            "color_scheme": {
              "type": "object",
              "properties": {
                "primary": {
                  "type": "string",
                  "description": "Primary color (hex or rgb)"
                },
                "secondary": {
                  "type": "string"
                },
                "background": {
                  "type": "string"
                }
              }
            }
          }
        },
        "icon": {
          "type": "object",
          "description": "Simple icon representation (for type: 'icon')",
          "properties": {
            "icon_path": {
              "type": "string",
              "description": "Path to icon file (SVG/PNG recommended)"
            },
            "shape": {
              "type": "string",
              "enum": ["circle", "square", "rounded-square", "hexagon"],
              "default": "circle"
            },
            "size": {
              "type": "integer",
              "description": "Icon size in pixels",
              "minimum": 32,
              "maximum": 512,
              "default": 128
            },
            "background_color": {
              "type": "string",
              "description": "Background color (hex or rgb)"
            }
          }
        },
        "image": {
          "type": "object",
          "description": "Static image representation (for type: 'image')",
          "properties": {
            "image_path": {
              "type": "string",
              "description": "Path to character image"
            },
            "crop": {
              "type": "object",
              "description": "Image cropping configuration",
              "properties": {
                "x": {
                  "type": "integer"
                },
                "y": {
                  "type": "integer"
                },
                "width": {
                  "type": "integer"
                },
                "height": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "position": {
          "type": "string",
          "description": "Position on screen (for dialogue scenes)",
          "enum": ["left", "right", "center", "top_left", "top_right", "bottom_left", "bottom_right"],
          "default": "left"
        },
        "size_preset": {
          "type": "string",
          "description": "Size preset for character display",
          "enum": ["small", "medium", "large", "full-screen"],
          "default": "medium"
        }
      }
    },
    "dialogue_style": {
      "type": "object",
      "description": "Dialogue presentation style",
      "properties": {
        "text_box": {
          "type": "object",
          "description": "Text box configuration (for subtitles/dialogue)",
          "properties": {
            "style": {
              "type": "string",
              "enum": ["bubble", "bar", "overlay", "none"],
              "default": "bubble"
            },
            "background_color": {
              "type": "string",
              "description": "Text box background color",
              "default": "rgba(0, 0, 0, 0.8)"
            },
            "text_color": {
              "type": "string",
              "default": "#FFFFFF"
            },
            "font_size": {
              "type": "integer",
              "minimum": 12,
              "maximum": 72,
              "default": 24
            },
            "font_family": {
              "type": "string",
              "default": "sans-serif"
            },
            "padding": {
              "type": "integer",
              "description": "Padding in pixels",
              "default": 16
            },
            "border_radius": {
              "type": "integer",
              "description": "Border radius in pixels",
              "default": 8
            }
          }
        },
        "animation": {
          "type": "object",
          "description": "Animation settings for character appearance",
          "properties": {
            "enter": {
              "type": "string",
              "enum": ["fade", "slide_in", "pop", "none"],
              "default": "fade"
            },
            "exit": {
              "type": "string",
              "enum": ["fade", "slide_out", "pop", "none"],
              "default": "fade"
            },
            "speaking_indicator": {
              "type": "boolean",
              "description": "Show visual indicator when speaking",
              "default": true
            },
            "pulse_on_speak": {
              "type": "boolean",
              "description": "Subtle pulse animation when speaking",
              "default": true
            }
          }
        }
      }
    },
    "personality": {
      "type": "object",
      "description": "Character personality traits (for future AI dialogue generation)",
      "properties": {
        "traits": {
          "type": "array",
          "description": "Personality traits",
          "items": {
            "type": "string",
            "enum": [
              "formal",
              "casual",
              "enthusiastic",
              "calm",
              "humorous",
              "serious",
              "friendly",
              "professional",
              "technical",
              "beginner-friendly"
            ]
          }
        },
        "speaking_pattern": {
          "type": "string",
          "description": "Characteristic speaking pattern",
          "examples": [
            "Uses technical jargon frequently",
            "Speaks in short, simple sentences",
            "Uses analogies and examples",
            "Asks clarifying questions"
          ]
        },
        "expertise_level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "expert", "professional"],
          "default": "intermediate"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string",
          "description": "Creator of this character definition"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "default": "1.0.0"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "description": "Internal notes about this character"
        }
      }
    }
  },
  "examples": [
    {
      "character_id": "narrator",
      "name": "Narrator",
      "role": "narrator",
      "voice": {
        "provider": "google-cloud-tts",
        "voice_id": "ja-JP-Neural2-B",
        "language": "ja",
        "speed": 1.1,
        "style": "professional"
      },
      "appearance": {
        "type": "icon",
        "icon": {
          "icon_path": "assets/icons/narrator.svg",
          "shape": "circle",
          "size": 96,
          "background_color": "#667eea"
        },
        "position": "left"
      }
    },
    {
      "character_id": "expert-reviewer",
      "name": "Expert Reviewer",
      "role": "expert",
      "voice": {
        "provider": "elevenlabs",
        "voice_id": "elevenlabs:josh",
        "language": "en-US",
        "style": "authoritative"
      },
      "appearance": {
        "type": "avatar",
        "avatar": {
          "style": "minimalist",
          "base_image": "assets/avatars/expert.png",
          "color_scheme": {
            "primary": "#10b981",
            "secondary": "#065f46"
          }
        },
        "position": "right"
      },
      "personality": {
        "traits": ["professional", "technical", "calm"],
        "expertise_level": "expert"
      }
    },
    {
      "character_id": "aivis-narrator",
      "name": "Aivis Narrator",
      "role": "narrator",
      "voice": {
        "provider": "aivis",
        "language": "ja",
        "speed": 1.1,
        "style": "professional",
        "aivis": {
          "speaker_id": 888753760,
          "intonation_scale": 1.0,
          "pre_phoneme_length": 0.1,
          "post_phoneme_length": 0.1
        }
      },
      "appearance": {
        "type": "none"
      }
    },
    {
      "character_id": "voicevox-zundamon",
      "name": "ずんだもん",
      "role": "guide",
      "voice": {
        "provider": "voicevox",
        "language": "ja",
        "speed": 1.0,
        "style": "cheerful",
        "voicevox": {
          "speaker_id": 1,
          "intonation_scale": 1.2,
          "volume_scale": 1.0
        }
      },
      "appearance": {
        "type": "avatar",
        "avatar": {
          "style": "cartoon"
        },
        "position": "right"
      },
      "personality": {
        "traits": ["friendly", "enthusiastic", "beginner-friendly"],
        "expertise_level": "beginner"
      }
    }
  ],
  "additionalProperties": false
}
