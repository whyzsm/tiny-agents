{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/direction.schema.json",
  "title": "Direction Schema",
  "description": "演出システムのスキーマ。シーンごとの演出パラメータ（トランジション、強調、背景、タイミング）を定義します。",
  "version": "1.0.0",
  "type": "object",
  "required": ["scene_id", "transition", "emphasis", "background", "timing"],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "対象シーンのID（シナリオ内のシーンと一致する必要がある）",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "transition": {
      "type": "object",
      "description": "このシーンへのトランジション設定",
      "required": ["type", "duration_ms"],
      "properties": {
        "type": {
          "type": "string",
          "description": "トランジションの種類",
          "enum": ["fade", "slide_in", "zoom", "cut"]
        },
        "duration_ms": {
          "type": "integer",
          "description": "トランジションの長さ（ミリ秒）",
          "minimum": 0,
          "maximum": 2000,
          "default": 500
        },
        "easing": {
          "type": "string",
          "description": "イージング関数",
          "enum": ["linear", "easeIn", "easeOut", "easeInOut"],
          "default": "easeInOut"
        },
        "direction": {
          "type": "string",
          "description": "スライドの方向（slide_inの場合のみ）",
          "enum": ["left", "right", "top", "bottom"],
          "default": "right"
        }
      },
      "additionalProperties": false
    },
    "emphasis": {
      "type": "object",
      "description": "シーン内での強調表現",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "description": "強調レベル",
          "enum": ["high", "medium", "low"]
        },
        "text": {
          "type": "array",
          "description": "強調するテキスト要素（キーワード・フレーズ）",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "sound": {
          "type": "string",
          "description": "効果音の種類",
          "enum": ["none", "pop", "whoosh", "chime", "ding"],
          "default": "none"
        },
        "color": {
          "type": "string",
          "description": "強調カラー（HEX形式）",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#00F5FF"
        },
        "position": {
          "type": "string",
          "description": "強調要素の配置",
          "enum": ["center", "top", "bottom", "left", "right"],
          "default": "center"
        }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "description": "背景設定",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "背景の種類",
          "enum": ["cyberpunk", "corporate", "minimal", "gradient", "particles"]
        },
        "primary_color": {
          "type": "string",
          "description": "プライマリカラー（HEX形式）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "secondary_color": {
          "type": "string",
          "description": "セカンダリカラー（HEX形式）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "opacity": {
          "type": "number",
          "description": "背景の不透明度",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "blur": {
          "type": "boolean",
          "description": "背景にブラーを適用するか",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "timing": {
      "type": "object",
      "description": "シーン内のタイミング調整",
      "properties": {
        "delay_before_ms": {
          "type": "integer",
          "description": "シーン開始前の待機時間（ミリ秒）",
          "minimum": 0,
          "default": 0
        },
        "delay_after_ms": {
          "type": "integer",
          "description": "シーン終了後の待機時間（ミリ秒）",
          "minimum": 0,
          "default": 0
        },
        "audio_start_offset_ms": {
          "type": "integer",
          "description": "音声開始オフセット（ミリ秒、正=遅延、負=早める）",
          "default": 1000
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
