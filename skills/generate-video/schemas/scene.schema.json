{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.dev/schemas/video/scene.schema.json",
  "title": "Video Scene Schema",
  "description": "Defines an individual video scene with content, direction, and assets",
  "type": "object",
  "version": "1.0.0",
  "required": ["scene_id", "section_id", "order", "type", "content"],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "Unique identifier for the scene",
      "pattern": "^[a-z0-9-]+$"
    },
    "section_id": {
      "type": "string",
      "description": "ID of the section this scene belongs to",
      "pattern": "^[a-z0-9-]+$"
    },
    "order": {
      "type": "integer",
      "description": "Order of the scene within its section (0-indexed)",
      "minimum": 0
    },
    "type": {
      "type": "string",
      "description": "Type of scene content",
      "enum": [
        "intro",
        "ui-demo",
        "architecture",
        "code-highlight",
        "changelog",
        "cta",
        "feature-highlight",
        "problem-promise",
        "workflow",
        "objection",
        "custom"
      ]
    },
    "content": {
      "type": "object",
      "description": "Scene content configuration",
      "required": ["duration_ms"],
      "properties": {
        "text": {
          "type": "string",
          "description": "Primary text content for the scene"
        },
        "image": {
          "type": "string",
          "description": "Path to image asset (relative or absolute)"
        },
        "duration_ms": {
          "type": "integer",
          "description": "Duration of the scene in milliseconds",
          "minimum": 100
        },
        "title": {
          "type": "string",
          "description": "Scene title"
        },
        "subtitle": {
          "type": "string",
          "description": "Scene subtitle or tagline"
        },
        "url": {
          "type": "string",
          "description": "URL for Playwright capture or external resource",
          "format": "uri"
        },
        "actions": {
          "type": "array",
          "description": "Playwright actions for UI demo scenes",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["click", "type", "wait", "scroll", "hover", "keypress"]
              },
              "selector": {
                "type": "string",
                "description": "CSS selector or data-testid"
              },
              "value": {
                "description": "Value for type actions or wait duration",
                "oneOf": [
                  { "type": "string" },
                  { "type": "number" }
                ]
              }
            }
          }
        },
        "mermaid": {
          "type": "string",
          "description": "Mermaid diagram definition for architecture scenes"
        },
        "code": {
          "type": "object",
          "description": "Code snippet for code-highlight scenes",
          "properties": {
            "language": {
              "type": "string"
            },
            "snippet": {
              "type": "string"
            },
            "highlights": {
              "type": "array",
              "items": {
                "type": "integer"
              },
              "description": "Line numbers to highlight"
            }
          }
        }
      }
    },
    "direction": {
      "type": "object",
      "description": "Visual direction and effects for the scene",
      "properties": {
        "transition": {
          "type": "object",
          "description": "Transition effects",
          "properties": {
            "in": {
              "type": "string",
              "enum": ["fade", "slide_in", "zoom", "cut"],
              "default": "fade"
            },
            "out": {
              "type": "string",
              "enum": ["fade", "slide_in", "zoom", "cut"],
              "default": "fade"
            },
            "duration_ms": {
              "type": "integer",
              "description": "Transition duration in milliseconds",
              "minimum": 0,
              "maximum": 2000,
              "default": 500
            }
          }
        },
        "emphasis": {
          "type": "object",
          "description": "Emphasis and highlighting",
          "properties": {
            "effect": {
              "type": "string",
              "enum": ["glitch", "pulse", "shake", "highlight", "none"]
            },
            "timing": {
              "type": "string",
              "description": "When to apply effect (e.g., '2s', '50%')"
            }
          }
        },
        "background": {
          "type": "object",
          "description": "Background configuration",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["solid", "gradient", "image", "video", "particles"]
            },
            "value": {
              "type": "string",
              "description": "Color, gradient definition, or asset path"
            },
            "opacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 1
            }
          }
        },
        "camera": {
          "type": "object",
          "description": "Camera movement (3D effects)",
          "properties": {
            "movement": {
              "type": "string",
              "enum": ["static", "pan", "zoom", "rotate", "parallax"]
            },
            "start": {
              "type": "object",
              "description": "Starting position/rotation"
            },
            "end": {
              "type": "object",
              "description": "Ending position/rotation"
            }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "description": "Assets used in this scene",
      "items": {
        "type": "object",
        "required": ["type", "source"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["image", "video", "audio", "font", "data"]
          },
          "source": {
            "type": "string",
            "description": "Path or URL to the asset"
          },
          "generated": {
            "type": "boolean",
            "description": "Whether this asset was AI-generated",
            "default": false
          },
          "metadata": {
            "type": "object",
            "description": "Additional metadata about the asset",
            "properties": {
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              },
              "duration_ms": {
                "type": "integer"
              },
              "format": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "audio": {
      "type": "object",
      "description": "Audio configuration for the scene",
      "properties": {
        "narration": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Narration text"
            },
            "file": {
              "type": "string",
              "description": "Path to narration audio file"
            },
            "start_offset_ms": {
              "type": "integer",
              "description": "Delay before narration starts (typically 1000ms)",
              "default": 1000
            }
          }
        },
        "sfx": {
          "type": "array",
          "description": "Sound effects",
          "items": {
            "type": "object",
            "properties": {
              "file": {
                "type": "string"
              },
              "timing_ms": {
                "type": "integer"
              },
              "volume": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "template": {
      "type": "string",
      "description": "Template name if using a predefined template"
    },
    "notes": {
      "type": "string",
      "description": "Internal notes for this scene"
    }
  }
}
