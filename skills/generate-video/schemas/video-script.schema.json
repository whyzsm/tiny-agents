{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.dev/schemas/video/video-script.schema.json",
  "title": "Video Script Schema",
  "description": "Complete video script with metadata, scenes, and output settings",
  "type": "object",
  "version": "1.0.0",
  "required": ["metadata", "scenes", "total_duration_ms", "output_settings"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Metadata about the video script",
      "required": ["title", "version", "created_at"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Video title",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "description": "Video description"
        },
        "version": {
          "type": "string",
          "description": "Script version",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of script creation",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last update",
          "format": "date-time"
        },
        "author": {
          "type": "string",
          "description": "Script author or generator"
        },
        "project": {
          "type": "string",
          "description": "Project name or identifier"
        },
        "video_type": {
          "type": "string",
          "description": "Type of video",
          "enum": [
            "lp-teaser",
            "intro-demo",
            "release-notes",
            "architecture",
            "onboarding",
            "custom"
          ]
        },
        "tags": {
          "type": "array",
          "description": "Categorization tags",
          "items": {
            "type": "string"
          }
        },
        "scenario_id": {
          "type": "string",
          "description": "Reference to the scenario this script is based on"
        }
      }
    },
    "scenes": {
      "type": "array",
      "description": "Ordered list of video scenes",
      "minItems": 1,
      "items": {
        "$ref": "scene.schema.json"
      }
    },
    "total_duration_ms": {
      "type": "integer",
      "description": "Total duration of the video in milliseconds",
      "minimum": 0
    },
    "output_settings": {
      "type": "object",
      "description": "Video output configuration",
      "required": ["width", "height", "fps"],
      "properties": {
        "width": {
          "type": "integer",
          "description": "Video width in pixels",
          "minimum": 320,
          "maximum": 7680
        },
        "height": {
          "type": "integer",
          "description": "Video height in pixels",
          "minimum": 240,
          "maximum": 4320
        },
        "fps": {
          "type": "integer",
          "description": "Frames per second",
          "enum": [24, 25, 30, 50, 60],
          "default": 30
        },
        "codec": {
          "type": "string",
          "description": "Video codec",
          "enum": ["h264", "h265", "vp8", "vp9", "av1"],
          "default": "h264"
        },
        "format": {
          "type": "string",
          "description": "Output format",
          "enum": ["mp4", "webm", "mov", "gif"],
          "default": "mp4"
        },
        "quality": {
          "type": "string",
          "description": "Output quality preset",
          "enum": ["low", "medium", "high", "ultra"],
          "default": "high"
        },
        "bitrate": {
          "type": "string",
          "description": "Video bitrate (e.g., '5M', '10M')"
        },
        "preset": {
          "type": "string",
          "description": "Encoding preset for resolution",
          "enum": [
            "240p",
            "360p",
            "480p",
            "720p",
            "1080p",
            "1440p",
            "4k",
            "custom"
          ]
        }
      }
    },
    "audio_settings": {
      "type": "object",
      "description": "Global audio settings",
      "properties": {
        "bgm": {
          "type": "object",
          "description": "Background music configuration",
          "properties": {
            "file": {
              "type": "string",
              "description": "Path to BGM file"
            },
            "volume": {
              "type": "number",
              "description": "BGM volume (0.0 - 1.0)",
              "minimum": 0,
              "maximum": 1,
              "default": 0.3
            },
            "fade_in_ms": {
              "type": "integer",
              "description": "Fade in duration in milliseconds",
              "minimum": 0,
              "default": 1000
            },
            "fade_out_ms": {
              "type": "integer",
              "description": "Fade out duration in milliseconds",
              "minimum": 0,
              "default": 2000
            },
            "loop": {
              "type": "boolean",
              "description": "Whether to loop the BGM",
              "default": true
            }
          }
        },
        "master_volume": {
          "type": "number",
          "description": "Master volume (0.0 - 1.0)",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        }
      }
    },
    "branding": {
      "type": "object",
      "description": "Branding configuration",
      "properties": {
        "logo": {
          "type": "string",
          "description": "Path to logo file"
        },
        "colors": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "description": "Primary brand color (hex or rgb)"
            },
            "secondary": {
              "type": "string",
              "description": "Secondary brand color"
            },
            "accent": {
              "type": "string",
              "description": "Accent color"
            },
            "background": {
              "type": "string",
              "description": "Default background color"
            },
            "text": {
              "type": "string",
              "description": "Default text color"
            }
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "description": "Primary font family or path to font file"
            },
            "secondary": {
              "type": "string",
              "description": "Secondary font family"
            },
            "monospace": {
              "type": "string",
              "description": "Monospace font for code"
            }
          }
        }
      }
    },
    "transitions": {
      "type": "object",
      "description": "Global transition settings",
      "properties": {
        "default_duration_ms": {
          "type": "integer",
          "description": "Default transition duration in milliseconds",
          "minimum": 0,
          "maximum": 2000,
          "default": 500
        },
        "overlap_ms": {
          "type": "integer",
          "description": "Overlap duration between scenes (for cross-fade)",
          "minimum": 0,
          "maximum": 1000,
          "default": 450
        },
        "type": {
          "type": "string",
          "description": "Default transition type",
          "enum": ["fade", "slide_in", "zoom", "cut"],
          "default": "fade"
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "General notes about the video script"
    }
  }
}
