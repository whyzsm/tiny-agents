{
  "$schema": "../schemas/video-script.schema.json",
  "metadata": {
    "title": "{{PROJECT_NAME}} - Landing Page Teaser",
    "description": "90-second teaser video following pain→solution→CTA narrative structure",
    "version": "1.0.0",
    "created_at": "{{TIMESTAMP}}",
    "author": "claude-code-harness/generate-video",
    "project": "{{PROJECT_ID}}",
    "video_type": "lp-teaser",
    "tags": ["landing-page", "teaser", "social-media", "ads"]
  },
  "scenes": [
    {
      "scene_id": "hook",
      "section_id": "hook",
      "order": 0,
      "type": "intro",
      "content": {
        "text": "{{HOOK_TEXT}}",
        "duration_ms": 5000,
        "title": "{{PROJECT_NAME}}",
        "subtitle": "{{TAGLINE}}"
      },
      "direction": {
        "transition": {
          "in": "fade",
          "out": "fade",
          "duration_ms": 500
        },
        "background": {
          "type": "gradient",
          "value": "linear-gradient(135deg, {{PRIMARY_COLOR}} 0%, {{SECONDARY_COLOR}} 100%)"
        }
      },
      "assets": [
        {
          "type": "image",
          "source": "{{GENERATED_ASSETS_DIR}}/hook.png",
          "generated": true,
          "prompt_template": "comparison"
        }
      ],
      "template": "intro",
      "notes": "Hook: Capture attention with pain or desired result. Use comparison visual pattern."
    },
    {
      "scene_id": "problem-promise",
      "section_id": "problem-promise",
      "order": 1,
      "type": "problem-promise",
      "content": {
        "text": "{{PROBLEM_STATEMENT}}",
        "duration_ms": 10000,
        "subtitle": "{{PROMISE_STATEMENT}}"
      },
      "direction": {
        "transition": {
          "in": "slide_in",
          "out": "fade",
          "duration_ms": 500
        },
        "background": {
          "type": "solid",
          "value": "{{BACKGROUND_COLOR}}"
        },
        "emphasis": {
          "effect": "highlight",
          "timing": "5s"
        }
      },
      "assets": [],
      "notes": "Problem+Promise: Define target user and make a promise. Text-heavy scene."
    },
    {
      "scene_id": "workflow-demo",
      "section_id": "workflow",
      "order": 2,
      "type": "ui-demo",
      "content": {
        "text": "{{WORKFLOW_DESCRIPTION}}",
        "duration_ms": 40000,
        "url": "{{APP_URL}}/{{WORKFLOW_PATH}}",
        "actions": "{{WORKFLOW_ACTIONS}}"
      },
      "direction": {
        "transition": {
          "in": "fade",
          "out": "fade",
          "duration_ms": 500
        }
      },
      "assets": [],
      "audio": {
        "narration": {
          "text": "{{WORKFLOW_NARRATION}}",
          "file": "{{AUDIO_DIR}}/workflow.mp3",
          "start_offset_ms": 1000
        }
      },
      "template": "ui-demo",
      "notes": "Workflow: Show the iconic workflow. 40 seconds to demonstrate core value."
    },
    {
      "scene_id": "differentiator",
      "section_id": "differentiator",
      "order": 3,
      "type": "feature-highlight",
      "content": {
        "text": "{{DIFFERENTIATOR_TEXT}}",
        "duration_ms": 15000,
        "title": "{{UNIQUE_FEATURE_TITLE}}"
      },
      "direction": {
        "transition": {
          "in": "zoom",
          "out": "fade",
          "duration_ms": 500
        },
        "emphasis": {
          "effect": "pulse",
          "timing": "3s"
        }
      },
      "assets": [
        {
          "type": "image",
          "source": "{{GENERATED_ASSETS_DIR}}/differentiator.png",
          "generated": true,
          "prompt_template": "concept"
        }
      ],
      "notes": "Differentiator: Show what makes this solution unique. Use concept visual pattern."
    },
    {
      "scene_id": "cta",
      "section_id": "cta",
      "order": 4,
      "type": "cta",
      "content": {
        "text": "{{CTA_TEXT}}",
        "duration_ms": 20000,
        "url": "{{CTA_URL}}",
        "button_text": "{{CTA_BUTTON_TEXT}}"
      },
      "direction": {
        "transition": {
          "in": "fade",
          "out": "fade",
          "duration_ms": 800
        },
        "background": {
          "type": "solid",
          "value": "{{PRIMARY_COLOR}}"
        }
      },
      "assets": [
        {
          "type": "image",
          "source": "{{GENERATED_ASSETS_DIR}}/cta.png",
          "generated": true,
          "prompt_template": "highlight"
        }
      ],
      "template": "cta",
      "notes": "CTA: Clear call to action. 20 seconds to provide next steps and contact info."
    }
  ],
  "total_duration_ms": 90000,
  "output_settings": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "codec": "h264",
    "format": "mp4",
    "quality": "high",
    "preset": "1080p",
    "bitrate": "8M"
  },
  "audio_settings": {
    "bgm": {
      "file": "{{BGM_FILE}}",
      "volume": 0.25,
      "fade_in_ms": 1000,
      "fade_out_ms": 2000,
      "loop": true
    },
    "master_volume": 1.0
  },
  "branding": {
    "logo": "{{LOGO_PATH}}",
    "colors": {
      "primary": "{{PRIMARY_COLOR}}",
      "secondary": "{{SECONDARY_COLOR}}",
      "accent": "{{ACCENT_COLOR}}",
      "background": "{{BACKGROUND_COLOR}}",
      "text": "{{TEXT_COLOR}}"
    },
    "fonts": {
      "primary": "{{PRIMARY_FONT}}",
      "secondary": "{{SECONDARY_FONT}}",
      "monospace": "{{MONOSPACE_FONT}}"
    }
  },
  "transitions": {
    "default_duration_ms": 500,
    "overlap_ms": 450,
    "type": "fade"
  },
  "notes": "90-second LP teaser template. Follow the pain→solution→CTA narrative. Scene timings: Hook(5s) → Problem+Promise(10s) → Workflow(40s) → Differentiator(15s) → CTA(20s) = 90s total.",
  "_template_variables": {
    "PROJECT_NAME": "Your product name",
    "PROJECT_ID": "product-slug",
    "TIMESTAMP": "Auto-generated ISO 8601 timestamp",
    "TAGLINE": "One-line value proposition",
    "HOOK_TEXT": "Pain point or desired result (e.g., 'Tired of juggling multiple tools?')",
    "PROBLEM_STATEMENT": "Clear problem description targeting specific users",
    "PROMISE_STATEMENT": "What you promise to deliver",
    "WORKFLOW_DESCRIPTION": "Brief description of the core workflow",
    "WORKFLOW_NARRATION": "Narration script for workflow demo",
    "APP_URL": "URL to your app for Playwright capture",
    "WORKFLOW_PATH": "Path to workflow demo page",
    "WORKFLOW_ACTIONS": "Array of Playwright actions (see video-script.schema.json)",
    "DIFFERENTIATOR_TEXT": "What makes your solution unique",
    "UNIQUE_FEATURE_TITLE": "Title for your unique feature",
    "CTA_TEXT": "Call to action text",
    "CTA_URL": "URL for CTA button",
    "CTA_BUTTON_TEXT": "Button text (e.g., 'Start Free Trial')",
    "PRIMARY_COLOR": "Hex color (e.g., #667eea)",
    "SECONDARY_COLOR": "Hex color",
    "ACCENT_COLOR": "Hex color",
    "BACKGROUND_COLOR": "Hex color",
    "TEXT_COLOR": "Hex color",
    "PRIMARY_FONT": "Font family",
    "SECONDARY_FONT": "Font family",
    "MONOSPACE_FONT": "Font family for code",
    "LOGO_PATH": "Path to logo file",
    "BGM_FILE": "Path to background music file",
    "AUDIO_DIR": "Directory for narration audio files",
    "GENERATED_ASSETS_DIR": "Directory for AI-generated images"
  }
}
