{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-harness.local/schemas/plan-brief-context.v1.schema.json",
  "title": "plan-brief-context.v1",
  "description": "Plan Brief 用の context 構造体。harness-plan-brief skill が harness-mem search 結果から組み立てる。",
  "type": "object",
  "required": [
    "schema",
    "user_request",
    "my_understanding",
    "options",
    "risks",
    "acceptance_criteria",
    "confidence",
    "confidence_evidence",
    "related_decisions",
    "similar_past_plans",
    "project",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "plan-brief-context.v1"
    },
    "user_request": {
      "type": "string",
      "minLength": 1
    },
    "my_understanding": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "summary"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "pros": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cons": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "severity", "description"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["info", "warn", "critical"]
          },
          "description": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "verifiable_by": { "type": "string" }
        }
      }
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence_evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "relevance": { "type": "string" }
        }
      }
    },
    "similar_past_plans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["archive_path", "phase"],
        "additionalProperties": false,
        "properties": {
          "archive_path": { "type": "string" },
          "phase": { "type": "string" },
          "outcome": {
            "type": "string",
            "enum": ["cc:完了", "cc:WIP", "cc:TODO", "skipped", "unknown"]
          },
          "relevance": { "type": "string" }
        }
      }
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "confidence_evidence_items": {
      "type": "array",
      "description": "Derived rendering helper for render-html.sh. Each string in confidence_evidence is wrapped as {text: <string>} so the template can iterate via {{#confidence_evidence_items}}{{text}}{{/confidence_evidence_items}}. The compile script (Phase 65.1.3) populates this. Optional: not required by canonical context.",
      "items": {
        "type": "object",
        "required": ["text"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string" }
        }
      }
    }
  }
}
